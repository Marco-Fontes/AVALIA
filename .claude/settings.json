{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(alembic:*)",
      "Bash(psql:*)"
    ],
    "allow": [
      "Bash(py -m pytest:*)",
      "Bash(py -m ruff:*)",
      "Bash(py -m mypy:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_no_target_exec.py\"" },
          { "type": "command", "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_model_access.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/format.py\"" }
        ]
      }
    ]
  }
}
